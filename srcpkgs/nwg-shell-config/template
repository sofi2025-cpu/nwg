post_install() {
	for f in *.svg; do
		vinstall "$f" 644 usr/share/pixmaps
	done
	for f in *.desktop; do
		vinstall "$f" 644 usr/share/applications
	done
	vbin "${FILESDIR}/nwg-system-update"
	vdoc README.md
	vlicense LICENSE
}
